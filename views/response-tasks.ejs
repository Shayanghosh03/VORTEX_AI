<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/png" sizes="32x32" href="/images/geonex_logo.png" />
  <link rel="stylesheet" href="/stylesheets/style.css" />
  <script src="/javascripts/main.js" defer></script>
</head>
<body>
  <div class="wrapper">
    <div class="grid-bg"></div>
    <div class="scan-ring"></div>
    <div class="scan-ring"></div>
    <div class="scan-ring"></div>
    <div class="scan-ring"></div>

    <%- include('partials/Navbar', { activePage: 'response', currentUser }) %>

    <main>
      <div class="page-header">
        <div class="alert-badge"><div class="dot"></div> TASK QUEUE</div>
        <h1 class="hero-title">Active <span style="color:#00b4ff;">Tasks</span></h1>
        <p class="hero-sub">Field team assignments and deployment status across all active zones.</p>
      </div>

      <div class="panel panel-animate" style="margin-top:2rem; overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:11px; letter-spacing:1px; font-family:'Share Tech Mono',monospace;">
          <thead>
            <tr style="color:#00b4ff; border-bottom:1px solid rgba(0,180,255,0.2);">
              <th style="padding:10px; text-align:left;">ID</th>
              <th style="padding:10px; text-align:left;">ZONE</th>
              <th style="padding:10px; text-align:left;">TYPE</th>
              <th style="padding:10px; text-align:left;">TEAMS</th>
              <th style="padding:10px; text-align:left;">STATUS</th>
            </tr>
          </thead>
          <tbody style="color:rgba(200,220,240,0.8);">
            <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
              <td style="padding:10px;">C-214</td><td style="padding:10px;">Delta-3</td><td style="padding:10px;">Cyclone surge</td><td style="padding:10px;">4 deployed</td><td style="padding:10px; color:#ff4444;">CRITICAL</td>
            </tr>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
              <td style="padding:10px;">F-088</td><td style="padding:10px;">Bridge North</td><td style="padding:10px;">Flooding</td><td style="padding:10px;">2 en route</td><td style="padding:10px; color:#ffaa00;">HIGH</td>
            </tr>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
              <td style="padding:10px;">L-032</td><td style="padding:10px;">Sector 7</td><td style="padding:10px;">Landslide</td><td style="padding:10px;">1 staging</td><td style="padding:10px; color:#ffdd00;">MEDIUM</td>
            </tr>
            <tr>
              <td style="padding:10px;">C-221</td><td style="padding:10px;">Coastal ring</td><td style="padding:10px;">Cyclone wind</td><td style="padding:10px;">3 cleared</td><td style="padding:10px; color:#00cc88;">CLEARED</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div style="margin-top:1rem;">
        <a href="/response/tasks/export" class="btn btn-outline" style="font-size:11px;">Export CSV</a>
      </div>
    </main>
  </div>
</body>
</html>
