<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="/javascripts/main.js" defer></script>
  </head>
  <body>
    <div class="wrapper">
      <div class="grid-bg"></div>
      <div class="scan-ring"></div>
      <div class="scan-ring"></div>
      <div class="scan-ring"></div>
      <div class="scan-ring"></div>

      <div class="topbar">
        <div class="logo">
          <img src="../public/images/geonex_logo.png" alt="Geonex AI logo" class="logo-img" />
          <div>
             <div class="logo-text">Geonex AI</div>
            <div class="logo-sub">Predictive damage intelligence</div>
          </div>
        </div>
        <div class="nav-links">
          <a href="/" class="<%= activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
          <a href="/risk-map" class="<%= activePage === 'risk-map' ? 'active' : '' %>">Risk Map</a>
          <a href="/forecasts" class="<%= activePage === 'forecasts' ? 'active' : '' %>">Forecasts</a>
          <a href="/response" class="<%= activePage === 'response' ? 'active' : '' %>">Response</a>
          <a href="/reports" class="<%= activePage === 'reports' ? 'active' : '' %>">Reports</a>
        </div>
        <div class="topbar-right">
          <div class="status-dot">
            <div class="dot"></div>
            Live monitoring
          </div>
          <% if (!currentUser) { %>
            <a href="/login" class="topbar-login">Log in</a>
          <% } else { %>
            <form method="post" action="/logout" class="topbar-logout">
              <span class="topbar-user"><%= currentUser.name %></span>
              <button type="submit" class="topbar-login">Log out</button>
            </form>
          <% } %>
        </div>
      </div>

      <div class="hero">
        <div class="left-panel panel-animate">
          <div class="alert-badge">
            <div class="dot"></div>
            72H FORECAST — DETAILED TRACK
          </div>
          <h1 class="hero-title">
            <span class="hero-line hero-line-1">Full 72-hour</span>
            <span class="hero-line hero-line-2 accent">intensity &amp; rainfall</span>
            <span class="hero-line hero-line-3">window<span class="accent2">.</span></span>
          </h1>
          <p class="subtitle subtitle-animated">
            DETAILED 0–72H WINDOW FOR A SINGLE CYCLONE EVENT. SYNTHETIC
            DATA FOR UI DEMONSTRATION ONLY.
          </p>
          <div class="cta-row">
            <a href="/forecasts/download" class="btn-secondary">Download CSV Snapshot</a>
            <a href="/forecasts" class="btn-secondary">Back to Forecasts Overview</a>
          </div>
        </div>
        <div class="right-panel panel-animate-delayed">
          <div class="map-container mini-panel">
            <div class="data-card">
              <div class="data-card-header">· 72h intensity profile ·</div>
              <div class="data-row">
                <span class="data-key">Run ID</span>
                <span class="data-val">VTX-ENS-2048B</span>
              </div>
              <div class="data-row">
                <span class="data-key">Model blend</span>
                <span class="data-val">ECMWF / GFS / VORTEX-GEN</span>
              </div>
              <div class="data-row">
                <span class="data-key">Lead time</span>
                <span class="data-val">0–72 hours</span>
              </div>
              <div class="data-row">
                <span class="data-key">Update cadence</span>
                <span class="data-val">Every 30 minutes</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <section class="forecast-72h">
        <div class="forecast-72h__header">
          <span class="live-pill">72h outlook</span>
          <h2>Track intensity and impact over the next 72 hours</h2>
          <p>
            Synthetic ensemble output for a single cyclone event. Use for
            UI and download flows only — not real meteorological guidance.
          </p>
        </div>
        <div class="forecast-72h__grid">
          <div class="forecast-card">
            <div class="forecast-card__time">0–12h</div>
            <div class="forecast-card__metric">Wind: 45–60 kts</div>
            <div class="forecast-card__metric">Rainfall: 12–22 mm</div>
            <div class="forecast-card__risk forecast-card__risk--amber">Rising risk</div>
          </div>
          <div class="forecast-card">
            <div class="forecast-card__time">12–24h</div>
            <div class="forecast-card__metric">Wind: 60–80 kts</div>
            <div class="forecast-card__metric">Rainfall: 22–40 mm</div>
            <div class="forecast-card__risk forecast-card__risk--red">Peak impact window</div>
          </div>
          <div class="forecast-card">
            <div class="forecast-card__time">24–48h</div>
            <div class="forecast-card__metric">Wind: 70–90 kts</div>
            <div class="forecast-card__metric">Rainfall: 26–60 mm</div>
            <div class="forecast-card__risk forecast-card__risk--red">Sustained high risk</div>
          </div>
          <div class="forecast-card">
            <div class="forecast-card__time">48–72h</div>
            <div class="forecast-card__metric">Wind: 40–70 kts</div>
            <div class="forecast-card__metric">Rainfall: 4–26 mm</div>
            <div class="forecast-card__risk forecast-card__risk--green">Gradual weakening</div>
          </div>
        </div>
      </section>
    </div>
  </body>
  </html>
