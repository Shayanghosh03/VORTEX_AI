<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/stylesheets/style.css" />
  <link rel="icon" type="image/png" sizes="32x32" href="./images/geonex_logo.png" />

  <script src="/javascripts/main.js" defer></script>
  <script src="/javascripts/time.js"></script>
</head>

<body>
  <div class="wrapper">
    <div class="grid-bg"></div>

    <!-- Scan rings centered on map area -->
    <div class="scan-ring"></div>
    <div class="scan-ring"></div>
    <div class="scan-ring"></div>
    <div class="scan-ring"></div>

    <!-- Navbar -->
    <%- include('partials/Navbar', { activePage: 'dashboard' , currentUser }) %>


      <!-- Ticker bar -->
      <div class="ticker-bar">
        <div class="ticker-inner">
          ALERT: Cyclone Mocha — Bay of Bengal — CAT 4 — Landfall predicted
          T+18h — Damage risk: CRITICAL
          <span class="tick-sep">///</span>
          Seismic activity detected — Andaman Islands — M 5.1 — Structural
          damage probability 23%
          <span class="tick-sep">///</span>
          Flash flood watch — Assam River Basin — 480mm rainfall 72h forecast —
          Evacuation advisory issued
          <span class="tick-sep">///</span>
          Model update: GDP-loss estimate revised upward — Zone 7 — $2.3B
          exposure — 94% confidence interval
          <span class="tick-sep">///</span>
          AI prediction accuracy last 30d: 91.4% — 48 events correctly
          classified — 3 false positives
        </div>
      </div>

      <!-- Hero grid -->
      <div class="hero">
        <!-- Left panel -->
        <div class="left-panel">
          <div class="alert-badge">
            <div class="dot"></div>
            ACTIVE THREAT — <span>CYCLONE MOCHA</span>
          </div>
          <h1 class="hero-title">
            <span class="hero-line hero-line-1">Predict.</span>
            <span class="hero-line hero-line-2 accent">Prepare.</span>
            <span class="hero-line hero-line-3">Protect<span class="accent2">.</span></span>
          </h1>
          <p class="subtitle subtitle-animated">
            REAL-TIME DISASTER DAMAGE FORECASTING <br />
            TURN SATELLITE, DRONE & SENSOR DATA INTO ACTIONABLE RESPONSE PLANS.
          </p>
          <div class="cta-row">
            <a href="/damage-model" class="btn-primary">
              <i class="fa-solid fa-play"></i>Run Damage Model</a>
            <a href="/risk-map" class="btn-secondary">
              <i class="fa-regular fa-map"></i>View Risk Map</a>
          </div>
          <div class="stats-row home-stats-row">
            <div class="stat">
              <span class="stat-val">91.4%</span>
              <span class="stat-label">Prediction accuracy</span>
            </div>
            <div class="stat">
              <span class="stat-val amber">4.7M</span>
              <span class="stat-label">People at risk</span>
            </div>
            <div class="stat">
              <span class="stat-val red">CRITICAL</span>
              <span class="stat-label">Threat level</span>
            </div>
            <div class="stat">
              <span class="stat-val">18h</span>
              <span class="stat-label">Landfall ETA</span>
            </div>
          </div>
        </div>

        <!-- Right panel — SVG map -->
        <div class="right-panel">
          <div class="map-container">
            <svg width="100%" height="100%" viewBox="0 0 460 480" style="position: absolute; inset: 0">
              <defs>
                <radialGradient id="rg1" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#ff2010" stop-opacity="0.55" />
                  <stop offset="60%" stop-color="#ff4020" stop-opacity="0.25" />
                  <stop offset="100%" stop-color="#ff4020" stop-opacity="0" />
                </radialGradient>
                <radialGradient id="rg2" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#ff8800" stop-opacity="0.45" />
                  <stop offset="100%" stop-color="#ff8800" stop-opacity="0" />
                </radialGradient>
                <radialGradient id="rg3" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#ffcc00" stop-opacity="0.3" />
                  <stop offset="100%" stop-color="#ffcc00" stop-opacity="0" />
                </radialGradient>
                <linearGradient id="sweep" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#00b4ff" stop-opacity="0" />
                  <stop offset="85%" stop-color="#00b4ff" stop-opacity="0" />
                  <stop offset="95%" stop-color="#00b4ff" stop-opacity="0.4" />
                  <stop offset="100%" stop-color="#00b4ff" stop-opacity="0.15" />
                </linearGradient>
              </defs>

              <rect width="460" height="480" fill="#080c14" />

              <!-- Coastline and islands -->
              <path
                d="M 0 160 Q 40 140 80 155 L 90 200 Q 110 220 120 260 L 110 300 Q 100 340 115 380 L 130 420 L 0 420 Z"
                fill="#0f1c2c" stroke="rgba(0,180,255,0.2)" stroke-width="0.8" />
              <path
                d="M 80 155 Q 120 130 170 140 L 185 165 Q 190 190 180 220 L 160 250 Q 140 270 120 260 Q 110 240 90 200 Z"
                fill="#0f1c2c" stroke="rgba(0,180,255,0.2)" stroke-width="0.8" />
              <path d="M 170 140 Q 210 120 250 130 L 255 160 Q 245 180 230 200 L 200 210 Q 190 200 185 165 Z"
                fill="#0f1c2c" stroke="rgba(0,180,255,0.2)" stroke-width="0.8" />
              <path d="M 250 130 Q 280 115 310 125 L 320 155 Q 315 180 300 195 L 270 210 Q 255 190 255 160 Z"
                fill="#0f1c2c" stroke="rgba(0,180,255,0.2)" stroke-width="0.8" />
              <path d="M 150 280 Q 170 265 195 270 L 200 310 Q 190 340 175 355 L 155 345 Q 140 330 145 305 Z"
                fill="#0f1c2c" stroke="rgba(0,180,255,0.2)" stroke-width="0.8" />
              <ellipse cx="380" cy="280" rx="22" ry="14" fill="#0f1c2c" stroke="rgba(0,180,255,0.15)"
                stroke-width="0.8" />
              <ellipse cx="340" cy="350" rx="16" ry="10" fill="#0f1c2c" stroke="rgba(0,180,255,0.15)"
                stroke-width="0.8" />
              <ellipse cx="400" cy="380" rx="12" ry="8" fill="#0f1c2c" stroke="rgba(0,180,255,0.15)"
                stroke-width="0.8" />

              <!-- Grid lines -->
              <line x1="0" y1="120" x2="460" y2="120" stroke="rgba(0,180,255,0.06)" stroke-width="0.5" />
              <line x1="0" y1="200" x2="460" y2="200" stroke="rgba(0,180,255,0.06)" stroke-width="0.5" />
              <line x1="0" y1="280" x2="460" y2="280" stroke="rgba(0,180,255,0.06)" stroke-width="0.5" />
              <line x1="0" y1="360" x2="460" y2="360" stroke="rgba(0,180,255,0.06)" stroke-width="0.5" />
              <line x1="115" y1="0" x2="115" y2="480" stroke="rgba(0,180,255,0.06)" stroke-width="0.5" />
              <line x1="230" y1="0" x2="230" y2="480" stroke="rgba(0,180,255,0.06)" stroke-width="0.5" />
              <line x1="345" y1="0" x2="345" y2="480" stroke="rgba(0,180,255,0.06)" stroke-width="0.5" />

              <!-- Damage zones -->
              <ellipse cx="280" cy="200" rx="195" ry="180" fill="url(#rg3)" opacity="0.7" />
              <ellipse cx="300" cy="210" rx="120" ry="110" fill="url(#rg2)" opacity="0.85" />
              <ellipse cx="320" cy="220" rx="65" ry="60" fill="url(#rg1)" opacity="1" />

              <!-- Storm path and markers -->
              <path d="M 460 420 Q 420 380 380 320 Q 340 260 320 220 Q 300 180 290 120 Q 280 70 270 30" fill="none"
                stroke="#ff4030" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.7" />
              <polygon points="268,22 274,36 262,36" fill="#ff4030" opacity="0.7" />

              <circle cx="320" cy="220" r="18" fill="none" stroke="#ff4030" stroke-width="1.5" opacity="0.9" />
              <circle cx="320" cy="220" r="8" fill="rgba(255,60,40,0.25)" stroke="#ff5040" stroke-width="1" />
              <circle cx="320" cy="220" r="2.5" fill="#ff4030" />

              <path d="M 320 220 Q 345 195 355 170 Q 360 150 350 135" fill="none" stroke="rgba(255,60,40,0.3)"
                stroke-width="1.2" />
              <path d="M 320 220 Q 295 245 285 268 Q 280 290 292 305" fill="none" stroke="rgba(255,60,40,0.3)"
                stroke-width="1.2" />
              <path d="M 320 220 Q 347 240 362 262 Q 372 280 365 295" fill="none" stroke="rgba(255,60,40,0.25)"
                stroke-width="1" />
              <path d="M 320 220 Q 295 198 280 178 Q 270 160 278 145" fill="none" stroke="rgba(255,60,40,0.25)"
                stroke-width="1" />

              <!-- Impact markers -->
              <circle cx="120" cy="260" r="5" fill="none" stroke="#ffa030" stroke-width="1.2" opacity="0.8" />
              <circle cx="120" cy="260" r="2" fill="#ffa030" opacity="0.8" />
              <circle cx="175" cy="355" r="4" fill="none" stroke="#ffa030" stroke-width="1" opacity="0.7" />
              <circle cx="175" cy="355" r="1.8" fill="#ffa030" opacity="0.7" />
              <circle cx="90" cy="200" r="3.5" fill="none" stroke="#ffcc00" stroke-width="1" opacity="0.6" />
              <circle cx="90" cy="200" r="1.5" fill="#ffcc00" opacity="0.6" />
              <circle cx="150" cy="300" r="4.5" fill="none" stroke="#ff4030" stroke-width="1.2" opacity="0.9" />
              <circle cx="150" cy="300" r="2" fill="#ff4030" opacity="0.9" />

              <!-- Scan sweep overlay -->
              <rect width="460" height="480" fill="url(#sweep)" opacity="0.5" style="
                  transform-origin: 230px 240px;
                  animation: sweepRot 8s linear infinite;
                ">
                <animateTransform attributeName="transform" type="rotate" from="0 230 240" to="360 230 240" dur="8s"
                  repeatCount="indefinite" />
              </rect>

              <!-- Coordinate labels -->
              <text x="8" y="470" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(0,180,255,0.4)"
                letter-spacing="1">
                88°E
              </text>
              <text x="108" y="470" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(0,180,255,0.4)"
                letter-spacing="1">
                91°E
              </text>
              <text x="223" y="470" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(0,180,255,0.4)"
                letter-spacing="1">
                94°E
              </text>
              <text x="338" y="470" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(0,180,255,0.4)"
                letter-spacing="1">
                97°E
              </text>
              <text x="6" y="125" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(0,180,255,0.4)"
                letter-spacing="1">
                20°N
              </text>
              <text x="6" y="205" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(0,180,255,0.4)"
                letter-spacing="1">
                18°N
              </text>
              <text x="6" y="285" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(0,180,255,0.4)"
                letter-spacing="1">
                16°N
              </text>
              <text x="338" y="215" font-family="Share Tech Mono, monospace" font-size="10" fill="#ff6040"
                letter-spacing="1.5">
                MOCHA
              </text>
              <text x="338" y="228" font-family="Share Tech Mono, monospace" font-size="9" fill="rgba(255,96,64,0.7)"
                letter-spacing="1">
                CAT 4 · 240km/h
              </text>
            </svg>

            <!-- Data card -->
            <div class="data-card">
              <div class="data-card-header">· Damage forecast ·</div>
              <div class="data-row">
                <span class="data-key">Buildings at risk</span>
                <span class="data-val high">48,200</span>
              </div>
              <div class="data-row">
                <span class="data-key">Critical damage</span>
                <span class="data-val high">31%</span>
              </div>
              <div class="data-row">
                <span class="data-key">Moderate damage</span>
                <span class="data-val med">44%</span>
              </div>
              <div class="data-row">
                <span class="data-key">Minor damage</span>
                <span class="data-val low">25%</span>
              </div>
              <div class="data-row">
                <span class="data-key">Confidence</span>
                <span class="data-val">94.2%</span>
              </div>
              <div class="bar-row">
                <div class="bar-label">
                  <span>Structural risk index</span><span>HIGH</span>
                </div>
                <div class="bar-track">
                  <div class="bar-fill" style="width: 78%; background: #ff4030"></div>
                </div>
                <div class="bar-label">
                  <span>Flood exposure</span><span>CRITICAL</span>
                </div>
                <div class="bar-track">
                  <div class="bar-fill" style="width: 91%; background: #a855f7"></div>
                </div>
                <div class="bar-label">
                  <span>Response readiness</span><span>MED</span>
                </div>
                <div class="bar-track">
                  <div class="bar-fill" style="width: 52%; background: #ffa030"></div>
                </div>
              </div>
            </div>

            <!-- Zone legend -->
            <div class="zone-legend">
              <div class="legend-title">Damage zones</div>
              <div class="legend-item">
                <div class="legend-dot" style="background: #ff2010"></div>
                Critical impact
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background: #ff8800"></div>
                Severe warning
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background: #ffcc00"></div>
                Watch zone
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background: #00b4ff; opacity: 0.7"></div>
                Scan coverage
              </div>
            </div>
          </div>
        </div>
      </div>

      <%- include('partials/Footer') %>
  </div>
</body>

</html>