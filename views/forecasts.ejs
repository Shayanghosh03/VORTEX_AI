<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/png" sizes="32x32" href="./images/geonex_logo.png" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="/javascripts/main.js" defer></script>
  </head>
  <body>
    <div class="wrapper">
      <div class="grid-bg"></div>
      <div class="scan-ring"></div>
      <div class="scan-ring"></div>
      <div class="scan-ring"></div>
      <div class="scan-ring"></div>

      <div class="topbar">
        <div class="logo">
          <img src="./images/geonex_logo.png" alt="VORTEX AI logo" class="logo-img" />
          <div>
             <div class="logo-text">Geonex AI</div>
            <div class="logo-sub">Predictive damage intelligence</div>
          </div>
        </div>
        <div class="nav-links">
          <a href="/" class="<%= activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
          <a href="/risk-map" class="<%= activePage === 'risk-map' ? 'active' : '' %>">Risk Map</a>
          <a href="/forecasts" class="<%= activePage === 'forecasts' ? 'active' : '' %>">Forecasts</a>
          <a href="/response" class="<%= activePage === 'response' ? 'active' : '' %>">Response</a>
          <a href="/reports" class="<%= activePage === 'reports' ? 'active' : '' %>">Reports</a>
        </div>
        <div class="topbar-right">
          <div class="status-dot">
            <div class="dot"></div>
            Live 
          </div>
          <% if (!currentUser) { %>
            <a href="/login" class="topbar-login">Log in</a>
          <% } else { %>
            <form method="post" action="/logout" class="topbar-logout">
              <span class="topbar-user"><%= currentUser.name %></span>
              <button type="submit" class="topbar-login">Log out</button>
            </form>
          <% } %>
        </div>
      </div>

      <div class="hero">
        <div class="left-panel panel-animate">
          <div class="alert-badge">
            <div class="dot"></div>
            FORECASTS — 72H OUTLOOK
          </div>
          <h1 class="hero-title">
            <span class="hero-line hero-line-1">Forecast impact.</span>
            <span class="hero-line hero-line-2 accent">Not just weather.</span>
            <span class="hero-line hero-line-3">Economic and human risk<span class="accent2">.</span></span>
          </h1>
          <p class="subtitle subtitle-animated">
            ENSEMBLE AI MODELS GENERATE MULTI-SCENARIO DAMAGE CURVES,
            CONFIDENCE BANDS AND EARLY-WARNING THRESHOLDS FOR EVERY REGION.
          </p>
          <div class="cta-row">
            <a href="/forecasts/72h" class="btn-primary">View 72h Forecast</a>
            <a href="/forecasts/download" class="btn-secondary">Download Projections</a>
          </div>
        </div>
        <div class="right-panel panel-animate-delayed">
          <div class="map-container mini-panel">
            <div class="data-card">
              <div class="data-card-header">· 72h impact forecast ·</div>
              <div class="data-row">
                <span class="data-key">Events tracked</span>
                <span class="data-val">12</span>
              </div>
              <div class="data-row">
                <span class="data-key">High-risk zones</span>
                <span class="data-val high">7</span>
              </div>
              <div class="bar-row">
                <div class="bar-label"><span>GDP loss (est.)</span><span>▲</span></div>
                <div class="bar-track"><div class="bar-fill" style="width: 68%; background:#ff6020;"></div></div>
                <div class="bar-label"><span>Population at risk</span><span>4.7M</span></div>
                <div class="bar-track"><div class="bar-fill" style="width: 84%; background:#ff4030;"></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      
    </div>
  </body>
</html>
